<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Meorawr/wow-ui-schema/main/UI.xsd">
	<Include file="Support.lua"/>

	<Frame name="TRP3_SupportPageTemplate" mixin="TRP3_SupportPageMixin" virtual="true">
		<KeyValues>
			<KeyValue key="layoutType" value="TooltipDefaultLayout" type="string"/>
		</KeyValues>
		<Frames>
			<Frame parentKey="NineSlice" inherits="NineSlicePanelTemplate" useParentLevel="true"/>
			<Frame parentKey="ScrollBox" inherits="WowScrollBox">
				<Anchors>
					<Anchor point="TOPLEFT" x="5" y="-5"/>
					<Anchor point="BOTTOMRIGHT" x="-28" y="5"/>
				</Anchors>
				<Frames>
					<Frame parentKey="Content" inherits="VerticalLayoutFrame">
						<KeyValues>
							<KeyValue key="scrollable" value="true" type="boolean"/>
						</KeyValues>
						<Layers>
							<Layer>
								<Texture>
									<KeyValues>
										<KeyValue key="layoutIndex" value="1" type="number"/>
									</KeyValues>
									<Anchors/>
									<Size x="100" y="200"/>
									<Color r="1"/>
								</Texture>
								<Texture>
									<KeyValues>
										<KeyValue key="layoutIndex" value="2" type="number"/>
									</KeyValues>
									<Anchors/>
									<Size x="100" y="200"/>
									<Color g="1"/>
								</Texture>
								<Texture>
									<KeyValues>
										<KeyValue key="layoutIndex" value="3" type="number"/>
									</KeyValues>
									<Anchors/>
									<Size x="100" y="200"/>
									<Color b="1"/>
								</Texture>
								<Texture>
									<KeyValues>
										<KeyValue key="layoutIndex" value="4" type="number"/>
									</KeyValues>
									<Anchors/>
									<Size x="100" y="200"/>
									<Color r="1" b="1"/>
								</Texture>
							</Layer>
						</Layers>
					</Frame>
				</Frames>
			</Frame>
			<EventFrame parentKey="ScrollBar" inherits="WowTrimScrollBar">
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT" y="-1"/>
					<Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="BOTTOMRIGHT" y="-1"/>
				</Anchors>
			</EventFrame>
		</Frames>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</Frame>
</Ui>
